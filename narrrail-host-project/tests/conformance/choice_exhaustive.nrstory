meta:
  schemaVersion: 1
  storyId: choice_exhaustive
  entryNodeId: N_Choice

variables: []

nodes:
  - nodeId: N_Choice
    nodeType: Choice
    choiceMode: ExhaustiveUntilComplete
    choiceCompletionTargetNodeId: N_Complete
    choices:
      - textKey: A
        targetNodeId: N_A
      - textKey: B
        targetNodeId: N_B
    exitActions:
      - actionType: EmitEvent
        eventId: choice_exit

  - nodeId: N_A
    nodeType: Dialogue
    dialogue:
      speakerId: Hero
      textKey: branch_a

  - nodeId: N_B
    nodeType: Dialogue
    dialogue:
      speakerId: Hero
      textKey: branch_b

  - nodeId: N_Complete
    nodeType: Dialogue
    dialogue:
      speakerId: Hero
      textKey: complete

  - nodeId: N_End
    nodeType: End

edges:
  - sourceNodeId: N_A
    targetNodeId: N_Choice
    priority: 0
    condition:
      logic: All
      terms: []

  - sourceNodeId: N_B
    targetNodeId: N_Choice
    priority: 0
    condition:
      logic: All
      terms: []

  - sourceNodeId: N_Complete
    targetNodeId: N_End
    priority: 0
    condition:
      logic: All
      terms: []
