meta:
  schemaVersion: 1
  storyId: invalid_condition_variable
  entryNodeId: N_Start

variables: []

nodes:
  - nodeId: N_Start
    nodeType: Dialogue
    dialogue:
      speakerId: Hero
      textKey: start

  - nodeId: N_End
    nodeType: End

edges:
