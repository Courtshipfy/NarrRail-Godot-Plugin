meta:
  schemaVersion: 1
  storyId: emit_event_pause_resume
  entryNodeId: N_Start

variables: []

nodes:
  - nodeId: N_Start
    nodeType: Dialogue
    dialogue:
      speakerId: Hero
      textKey: start

  - nodeId: N_Delay
    nodeType: EmitEvent
    eventType: delay
    params:
      time: 1.0

  - nodeId: N_Choice
    nodeType: Choice
    choices:
      - textKey: continue
        targetNodeId: N_End

  - nodeId: N_End
    nodeType: End

edges:
  - sourceNodeId: N_Start
    targetNodeId: N_Delay
    priority: 0
    condition:
      logic: All
      terms: []
  - sourceNodeId: N_Delay
    targetNodeId: N_Choice
    priority: 0
    condition:
      logic: All
      terms: []
